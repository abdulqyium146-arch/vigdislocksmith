    {
      "@id": "https://vigdis.shop/#term-locksmith",
      "@type": "DefinedTerm",
      "name": "Locksmith",
      "description": "A tradesperson who works with locks, keys, and security systems. Services include lock installation, repair, replacement, key cutting, and emergency lockout resolution.",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#term-emergency-locksmith",
      "@type": "DefinedTerm",
      "name": "Emergency Locksmith",
      "description": "A certified locksmith available 24/7 to respond to urgent lock emergencies including lockouts, broken locks, and post-burglary security repairs. Vigdis Locksmith London offers 15-30 minute emergency response in Mayfair.",
      "url": "https://vigdis.shop/services/emergency-locksmith",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#term-nde",
      "@type": "DefinedTerm",
      "name": "Non-Destructive Entry",
      "description": "Professional locksmith technique to open a locked door without damaging the lock, using picking, decoding, or bypass tools.",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#term-euro-cylinder",
      "@type": "DefinedTerm",
      "name": "Euro Cylinder Lock",
      "description": "The most common lock type in UK doors. Available in anti-snap, anti-drill, anti-pick, and anti-bump security grades.",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#term-mortice",
      "@type": "DefinedTerm",
      "name": "Mortice Lock",
      "description": "Lock fitted inside a pocket cut in the door body. BS3621 mortice deadlocks are the gold standard for UK home security.",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#term-bs3621",
      "@type": "DefinedTerm",
      "name": "BS3621",
      "description": "British Standard for thief-resistant lock assemblies. Required by most UK home insurance policies.",
      "inDefinedTermSet": { "@id": "https://vigdis.shop/#locksmith-terms" }
    },

    {
      "@id": "https://vigdis.shop/#locksmith-terms",
      "@type": "DefinedTermSet",
      "name": "Locksmith Terminology",
      "description": "Authoritative definitions of locksmith and security terms by Vigdis Locksmith London",
      "url": "https://vigdis.shop/faq"
    },

